{
	"info": {
		"_postman_id": "learn-bruno-collection",
		"name": "learn-bruno",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8000"
		}
	],
	"item": [
		{
			"name": "items",
			"item": [
				{
					"name": "アイテム一覧取得",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/items",
							"host": ["{{baseUrl}}"],
							"path": ["items"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('ステータスコードが200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Content-Typeがapplication/json', function() {",
									"    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
									"});",
									"",
									"pm.test('レスポンスが配列', function() {",
									"    const body = pm.response.json();",
									"    pm.expect(body).to.be.an('array');",
									"});",
									"",
									"pm.test('各アイテムにid,nameプロパティがある', function() {",
									"    const body = pm.response.json();",
									"    body.forEach(item => {",
									"        pm.expect(item).to.have.property('id');",
									"        pm.expect(item).to.have.property('name');",
									"    });",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "アイテム取得",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/items/1",
							"host": ["{{baseUrl}}"],
							"path": ["items", "1"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('ステータスコードが200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('idが1', function() {",
									"    const body = pm.response.json();",
									"    pm.expect(body.id).to.eql(1);",
									"});",
									"",
									"pm.test('nameが文字列', function() {",
									"    const body = pm.response.json();",
									"    pm.expect(body.name).to.be.a('string');",
									"});"
								]
							}
						}
					]
				},
