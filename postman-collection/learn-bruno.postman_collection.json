											"});",
											"",
											"pm.test('名前が変更されている', function() {",
											"    const oldName = pm.collectionVariables.get('itemName');",
											"    const body = pm.response.json();",
											"    pm.expect(body.name).to.not.eql(oldName);",
											"    pm.expect(body.name).to.eql('Updated Item');",
											"});"
										]
									}
								}
