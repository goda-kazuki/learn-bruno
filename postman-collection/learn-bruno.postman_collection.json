								}
							},
							"response": [],
							"event": [
								{
									"listen": "prerequest",
									"script": {
										"type": "text/javascript",
										"exec": [
											"const id = pm.collectionVariables.get('createdId');",
											"if (!id) {",
											"    throw new Error('createdId is not set. Run 3_作成 first.');",
											"}"
										]
									}
								},
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
