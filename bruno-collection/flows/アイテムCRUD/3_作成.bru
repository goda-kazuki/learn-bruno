meta {
  name: 3_作成
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/items
  body: json
  auth: none
}

body:json {
  {
    "name": "New Item",
    "description": "A new item"
  }
}

assert {
  res.status: eq 201
  res.body.name: eq New Item
  res.body.description: eq A new item
  res.body.id: isNumber
}

script:post-response {
  const body = res.getBody();
  bru.setVar("createdId", body.id);
}
