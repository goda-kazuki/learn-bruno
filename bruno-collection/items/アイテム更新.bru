meta {
  name: アイテム更新
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/items/1
  body: json
  auth: none
}

body:json {
  {
    "name": "Updated Item",
    "description": "Updated description"
  }
}

assert {
  res.status: eq 200
  res.body.name: eq Updated Item
  res.body.description: eq Updated description
}
